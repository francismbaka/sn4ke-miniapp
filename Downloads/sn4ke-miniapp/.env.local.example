# ─── Your deployed Vercel URL ───────────────────────────────────────────────
NEXT_PUBLIC_URL=https://your-app.vercel.app

# ─── OnchainKit / CDP API Key ────────────────────────────────────────────────
# Get from: https://portal.cdp.coinbase.com → API Keys → Client API Key
NEXT_PUBLIC_ONCHAINKIT_API_KEY=

# ─── App name shown in wallet ────────────────────────────────────────────────
NEXT_PUBLIC_ONCHAINKIT_PROJECT_NAME=SN4KE

# ─── Farcaster manifest fields (filled after signing tool) ───────────────────
# Sign at: https://www.base.dev/preview?tab=account
FARCASTER_HEADER=
FARCASTER_PAYLOAD=
FARCASTER_SIGNATURE=

# ─── App assets (put images in /public folder) ───────────────────────────────
NEXT_PUBLIC_ICON_URL=https://your-app.vercel.app/icon.png
NEXT_PUBLIC_APP_SPLASH_IMAGE=https://your-app.vercel.app/splash.png
NEXT_PUBLIC_SPLASH_BACKGROUND_COLOR=#060610
NEXT_PUBLIC_APP_HERO_IMAGE=https://your-app.vercel.app/splash.png
NEXT_PUBLIC_APP_PRIMARY_CATEGORY=gaming
NEXT_PUBLIC_APP_SUBTITLE=Retro snake on Base
NEXT_PUBLIC_APP_DESCRIPTION=Classic pixel snake with on-chain leaderboard on Base.
NEXT_PUBLIC_APP_TAGLINE=Eat. Score. Chain.
NEXT_PUBLIC_APP_OG_TITLE=SN4KE on Base
NEXT_PUBLIC_APP_OG_DESCRIPTION=Retro pixel snake with on-chain leaderboard on Base.
NEXT_PUBLIC_APP_OG_IMAGE=https://your-app.vercel.app/splash.png

# ─── Your deployed SnakeLeaderboard contract address ─────────────────────────
NEXT_PUBLIC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ─── Wallet that collects play fees ──────────────────────────────────────────
NEXT_PUBLIC_TREASURY=0x0000000000000000000000000000000000000000

# ─── ETH fee per game session ────────────────────────────────────────────────
NEXT_PUBLIC_PLAY_FEE=0.0005

# ─── Chain: "base" for mainnet, "base-sepolia" for testnet ───────────────────
NEXT_PUBLIC_CHAIN=base-sepolia
